# Kynetic Sentra - Environment Configuration

# ── General Settings ──────────────────────────────────────────────────────────
APP_NAME="Kynetic Sentra"
APP_VERSION="1.0.0"
DEBUG=false

# ── AI Configuration (Groq Cloud LLM) ────────────────────────────────────────
# Get your free API key at: https://console.groq.com/keys
GROQ_API_KEY="your_api_key_here"
GROQ_MODEL="llama-3.3-70b-versatile"

# ── Security & Network ────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Use * for wildcard (not recommended in prod).
ALLOWED_ORIGINS="http://localhost:3000,https://your-production-domain.com"

# ── Limits ────────────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
LOG_CHUNK_SIZE=5000
